# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=trading

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:5173

# JWT Secret (for future use)
JWT_SECRET=your_jwt_secret_here

# Environment
NODE_ENV=development

# Brevo (Sendinblue) Email Configuration
# Sign up at: https://www.brevo.com/
# Get your SMTP API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=your_sender_email@example.com
FROM_NAME=AVATA Trading
ADMIN_NOTIFICATION_EMAIL=your_admin_email@example.com
FORCE_ALL_ORDER_EMAIL_TO_ADMIN=true